# Токен бота з @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Канал: @username каналу або числовий chat_id (бот має бути адміном)
TELEGRAM_CHANNEL=@my_news_channel

# Безкоштовний ключ з https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Необов'язково: модель Gemini (за замовчуванням gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
